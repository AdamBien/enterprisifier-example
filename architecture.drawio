        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- EDGES — ACL → CONFIG (cross-lane)                               -->
        <!-- ═══════════════════════════════════════════════════════════════ -->

        <!-- GreetingACLFacade → GreetingServiceLocator -->
        <mxCell id="e-aclfacade-locator" value="resolves via" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#000000;fontColor=#000000;fontSize=10;fontStyle=0;endArrow=block;endFill=1;shadow=0;" edge="1" source="acl-facade" target="cfg-locator" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- EDGES — CONFIG LAYER                                            -->
        <!-- ═══════════════════════════════════════════════════════════════ -->

        <!-- GreetingModule → GreetingRegistry -->
        <mxCell id="e-module-registry" value="registers" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#000000;fontColor=#000000;fontSize=10;fontStyle=0;endArrow=block;endFill=1;shadow=0;" edge="1" source="cfg-module" target="cfg-registry" parent="lane-config">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- GreetingRegistry → GreetingServiceLocator -->
        <mxCell id="e-registry-locator" value="populates" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#000000;fontColor=#000000;fontSize=10;fontStyle=0;endArrow=block;endFill=1;shadow=0;" edge="1" source="cfg-registry" target="cfg-locator" parent="lane-config">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- GreetingServiceLocator → DefaultGreetingServiceImpl -->
        <mxCell id="e-locator-svcimpl" value="provides" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#000000;fontColor=#000000;fontSize=10;fontStyle=0;endArrow=block;endFill=1;shadow=0;" edge="1" source="cfg-locator" target="cfg-svc-impl" parent="lane-config">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DefaultGreetingServiceImpl → GreetingService (API wires up) -->
        <mxCell id="e-svcimpl-apisvc" value="wires" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#000000;fontColor=#000000;fontSize=10;fontStyle=0;endArrow=block;endFill=1;shadow=0;" edge="1" source="cfg-svc-impl" target="a-service" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- LEGEND                                                           -->
        <!-- ═══════════════════════════════════════════════════════════════ -->

        <!-- Legend container -->
        <mxCell id="legend-box" value="Legend" style="swimlane;startSize=30;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;fontSize=13;fontStyle=1;whiteSpace=wrap;html=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2760" y="1220" width="480" height="220" as="geometry"/>
        </mxCell>

        <!-- Creational (yellow) -->
        <mxCell id="leg-creational" value="Creational Pattern" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;arcSize=10;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=12;fontStyle=0;" vertex="1" parent="legend-box">
          <mxGeometry x="20" y="45" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- Structural (blue) -->
        <mxCell id="leg-structural" value="Structural Pattern" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontSize=12;fontStyle=0;" vertex="1" parent="legend-box">
          <mxGeometry x="250" y="45" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- Behavioral (green) -->
        <mxCell id="leg-behavioral" value="Behavioral Pattern" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=12;fontStyle=0;" vertex="1" parent="legend-box">
          <mxGeometry x="20" y="105" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- Enterprise (orange) -->
        <mxCell id="leg-enterprise" value="Enterprise Pattern" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#000000;fontSize=12;fontStyle=0;" vertex="1" parent="legend-box">
          <mxGeometry x="250" y="105" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- ACL boundary arrow legend -->
        <mxCell id="leg-acl-label" value="ACL boundary crossing" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;overflow=hidden;fontColor=#000000;fontSize=11;fontStyle=1;" vertex="1" parent="legend-box">
          <mxGeometry x="120" y="163" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="leg-acl-arrow" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#d79b00;fontColor=#d79b00;fontSize=10;fontStyle=1;endArrow=block;endFill=1;dashed=1;shadow=0;" edge="1" source="leg-acl-label" target="leg-acl-label" parent="legend-box">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="30" y="178"/>
              <mxPoint x="110" y="178"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- small dashed line sample for ACL legend -->
        <mxCell id="leg-acl-line" value="" style="endArrow=block;endFill=1;dashed=1;strokeColor=#d79b00;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="legend-box">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="25" y="178" as="sourcePoint"/>
            <mxPoint x="110" y="178" as="targetPoint"/>
